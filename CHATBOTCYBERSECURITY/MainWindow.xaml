        </Border>

        <!-- Subtitle -->
        <Border Grid.Row="1" Background="#0F0F1E" Padding="0,0,0,12">
            <StackPanel>
                <TextBlock Text="ūüĒí  C Y B E R S E C U R I T Y   A W A R E N E S S   B O T  ūüĒí"
                           FontFamily="Consolas"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#00FF80"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Keeping You Safe in the Digital World"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#646478"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                <Rectangle Height="1" Fill="#B400FF" Margin="20,8,20,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="2"
                Background="#14142A"
                Margin="12,8,12,4"
                CornerRadius="6"
                BorderBrush="#1E1E3C"
                BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <RichTextBox x:Name="ChatBox"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="11"
                             Foreground="White"
                             Padding="8"
                             IsDocumentEnabled="True"
                             VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#0F0F1E" Padding="16,4">
            <TextBlock x:Name="StatusLabel"
                       Text="‚óŹ ONLINE  |  Type a message and press Enter or click Send"
                       FontFamily="Consolas"
                       FontSize="9"
                       Foreground="#00FF80"/>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="4"
                Background="#0F0F1E"
                Padding="12,8,12,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputBox"
                         Grid.Column="0"
                         Style="{StaticResource ChatInput}"
                         Height="40"
                         Margin="0,0,8,0"
                         KeyDown="InputBox_KeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="SEND ‚ě§"
                        Style="{StaticResource CyberpunkButton}"
                        Background="#00FF80"
                        Height="40"
                        Margin="0,0,6,0"
                        Click="SendButton_Click"/>

                <Button x:Name="HelpButton"
                        Grid.Column="2"
                        Content="HELP"
                        Style="{StaticResource CyberpunkButton}"
                        Background="#00C8FF"
                        Height="40"
                        Margin="0,0,6,0"
                        Click="HelpButton_Click"/>

                <Button x:Name="ClearButton"
                        Grid.Column="3"
                        Content="CLEAR"
                        Style="{StaticResource CyberpunkButton}"
                        Background="#B400FF"
                        Foreground="White"
                        Height="40"
                        Click="ClearButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
